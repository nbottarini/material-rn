{
  "name": "@material-rn/monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "lerna run build",
    "test": "lerna run test",
    "check-all": "yarn build && lerna run lint && lerna run test",
    "clean:dist": "lerna exec -- npx rimraf dist",
    "clean": "yarn clean:dist && lerna clean --yes && npx rimraf node_modules",
    "release": "git pull --tags origin && yarn lerna version --force-publish"
  },
  "packageManager": "yarn@4.17.0",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "dependencies": {
    "lerna": "^8.1.8",
    "react-native-pager-view": "^6.2.3",
    "react-native-tab-view": "^3.5.2"
  },
  "devDependencies": {
    "@material-rn/eslint-config-material": "workspace:~",
    "@material-rn/jest-config-material": "workspace:~",
    "@material-rn/typescript-config-material": "workspace:~",
    "@react-native/babel-preset": "^0.86.0",
    "@react-native/jest-preset": "~0.85.3",
    "@types/jest": "~29.5.14",
    "@types/node": "^22.7.8",
    "@types/react": "~19.2.2",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "babel-preset-expo": "~11.0.15",
    "eslint": "~8.57.1",
    "jest": "~29.7.0",
    "jest-each": "~29.7.0",
    "jest-extended": "~4.0.2",
    "prettier": "~3.3.3",
    "react": "~19.2.3",
    "react-native": "~0.85.3",
    "react-native-builder-bob": "~0.30.3",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "cheerio": "1.0.0-rc.12",
    "react-native": "0.85.3"
  }
}
