{
  "name": "@material-rn/catalog",
  "version": "0.1.6",
  "private": true,
  "scripts": {
    "lint": "yarn run eslint . && yarn run tsc --noEmit",
    "check-all": "yarn lint",
    "rebuild-native": "expo prebuild --clean",
