    "android": "expo run:android",
    "ios": "rm ios/.xcode.env.local || true && expo run:ios"
  },
  "eslintConfig": {
    "extends": "@material-rn/eslint-config-material"
  },
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "@expo/vector-icons": "^15.1.1",
    "@material-rn/core": "workspace:~",
    "@material-rn/stdlib": "workspace:~",
    "@react-native/metro-config": "^0.86.0",
    "@react-navigation/drawer": "^7.12.4",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "expo": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "lottie-react-native": "^7.3.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
