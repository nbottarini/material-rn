{
  "name": "@material-rn/catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "yarn run eslint . && yarn run tsc --noEmit",
    "check-all": "yarn lint",
    "rebuild-native": "expo prebuild --clean",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "rm ios/.xcode.env.local || true && expo run:ios"
  },
  "eslintConfig": {
    "extends": "@material-rn/eslint-config-material"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@material-rn/core": "workspace:~",
    "@material-rn/stdlib": "workspace:~",
    "@react-native/metro-config": "^0.74.88",
    "@react-navigation/drawer": "^6.7.2",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.38",
    "expo-blur": "~13.0.2",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-splash-screen": "~0.27.6",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.3",
    "lottie-react-native": "^7.1.0",
    "react": "18.3.1",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-pager-view": "^6.2.3",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "^4.14.0",
    "react-native-screens": "^3.35.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-toast-notifications": "^3.4.0"
  },
  "devDependencies": {
    "@material-rn/eslint-config-material": "workspace:~",
    "@material-rn/typescript-config-material": "workspace:~",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.73.0",
    "eslint": "~8.57.1",
    "typescript": "^5.4.5"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
