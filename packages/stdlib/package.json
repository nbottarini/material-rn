{
  "name": "@material-rn/stdlib",
  "version": "0.1.3",
  "main": "dist/commonjs/index.js",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "dist/typescript/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbottarini/material-rn.git"
  },
  "scripts": {
    "test": "yarn run -T jest",
    "lint": "yarn run -T eslint . && yarn run -T tsc --noEmit",
    "check-all": "yarn lint && yarn test",
    "build": "yarn run -T bob build"
  },
  "files": [
    "src",
    "dist",
    "!**/test",
    "!**/.*"
  ],
  "dependencies": {
    "@js-joda/core": "^5.6.3",
    "@nbottarini/abstract-logger": "^0.7.0",
    "@nbottarini/javascript-extensions": "^0.8.0",
    "@nbottarini/logger-api": "^0.7.0",
    "@nbottarini/money": "^0.9.8",
    "@nbottarini/observable": "^0.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest-extended": "^4.0.2"
  },
  "eslintConfig": {
    "extends": "@material-rn/eslint-config-material"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
