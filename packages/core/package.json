{
  "name": "@material-rn/core",
  "version": "0.1.0",
  "main": "dist/commonjs/public.js",
  "react-native": "src/public.ts",
  "source": "src/public.ts",
  "module": "dist/module/public.js",
  "types": "dist/typescript/public.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbottarini/material-rn.git"
  },
  "scripts": {
    "test": "yarn run -T jest",
    "lint": "yarn run -T eslint . && yarn run -T tsc --noEmit",
    "check-all": "yarn lint && yarn test",
    "build": "yarn run -T bob build"
  },
  "files": [
    "src",
    "dist",
    "!**/test",
    "!**/.*"
  ],
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@material-rn/stdlib": "workspace:^",
    "@nbottarini/react-native-relative-points": "^0.2.0",
    "@nbottarini/react-native-styled": "^0.8.5",
    "@nbottarini/react-presenter": "^0.12.2",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native": "^6.1.18",
    "color": "^4.2.3",
    "debounce": "~2.2.0",
    "lottie-react-native": "~7.1.0",
    "react-native-modal": "^13.0.1",
    "react-native-otp-entry": "^1.7.3",
    "react-native-toast-notifications": "~3.4.0"
  },
  "devDependencies": {
    "@types/color-convert": "^2.0.4",
    "lottie-react-native": "^7.1.0",
    "react-native-gesture-handler": "^2.20.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "^3.10.1",
    "react-native-safe-area-context": "^4.14.0"
  },
  "peerDependencies": {
    "expo": "^51",
    "lottie-react-native": "^7.1.0",
    "react": ">= 18.2.0",
    "react-native": ">= 0.74.5",
    "react-native-gesture-handler": "^2.20.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "^3.10.1",
    "react-native-safe-area-context": "^4.14.0"
  },
  "eslintConfig": {
    "extends": "@material-rn/eslint-config-material"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
