{
  "name": "@material-rn/core",
  "version": "0.1.2",
  "main": "dist/commonjs/public.js",
  "react-native": "src/public.ts",
  "source": "src/public.ts",
  "module": "dist/module/public.js",
  "types": "dist/typescript/public.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbottarini/material-rn.git"
  },
  "scripts": {
    "test": "yarn run -T jest",
    "lint": "yarn run -T eslint . && yarn run -T tsc --noEmit",
    "check-all": "yarn lint && yarn test",
    "build": "yarn run -T bob build"
  },
  "files": [
    "src",
    "dist",
    "!**/test",
    "!**/.*"
  ],
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@material-rn/stdlib": "workspace:^",
    "@nbottarini/react-native-relative-points": "^0.2.0",
    "@nbottarini/react-native-styled": "^0.8.5",
    "@nbottarini/react-presenter": "^0.12.2",
    "@react-navigation/elements": "^2.9.27",
    "@react-navigation/native": "^7.3.4",
    "color": "^5.0.3",
    "debounce": "~3.0.0",
    "lottie-react-native": "^7.3.8",
    "react-native-modal": "^13.0.2",
    "react-native-otp-entry": "^1.8.6",
    "react-native-toast-notifications": "~3.4.0"
  },
  "devDependencies": {
    "@types/color-convert": "^3.0.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0"
  },
  "peerDependencies": {
    "expo": "^56",
    "react": ">= 19.2.3",
    "react-native": ">= 0.85.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0"
  },
  "eslintConfig": {
    "extends": "@material-rn/eslint-config-material"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}